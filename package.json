{
  "name": "pi-vc-core",
  "version": "0.1.0",
  "description": "Windows-first local VC workspace, Office parsing, and Markdown memory package for Pi.",
  "type": "module",
  "private": true,
  "keywords": [
    "pi-package",
    "vc",
    "agent",
    "office",
    "memory",
    "web-search",
    "mcp"
  ],
  "scripts": {
    "check": "node --check scripts/check-package.mjs && npx tsc --noEmit",
    "smoke": "npx tsc --outDir .tmp-build --noEmit false && node scripts/smoke.mjs",
    "doctor": "pi --version"
  },
  "pi": {
    "extensions": [
      "./extensions/vc-project-workspace/index.ts",
      "./extensions/vc-office-core/index.ts",
      "./extensions/vc-memory/index.ts",
      "./node_modules/pi-web-access/index.ts",
      "./node_modules/pi-mcp-adapter/index.ts"
    ],
    "skills": [
      "./skills",
      "./node_modules/pi-web-access/skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "pdf-parse": "^2.4.5",
    "pi-mcp-adapter": "^2.10.0",
    "pi-web-access": "^0.13.0"
  },
  "bundledDependencies": [
    "pi-mcp-adapter",
    "pi-web-access"
  ],
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.8.3"
  }
}
